# Copy to ".env" in this same folder (Docker Compose loads it automatically for ${VAR} substitution).
# cp .env.example .env

# ─── Docker Compose (used by both docker-compose.dev.yml and docker-compose.prod.yml)
DOCKER_REPO=grading-system
IMAGE_TAG=latest
API_PORT=5049
POSTGRES_PUBLISH_PORT=5432
SQLSERVER_PUBLISH_PORT=1433
RABBITMQ_AMQP_PORT=5672
RABBITMQ_UI_PORT=15672
PGWEB_PORT=8081

# ─── PostgreSQL
POSTGRES_DB=grading_system
POSTGRES_USER=postgres
POSTGRES_PASSWORD=grading_pass

# ─── SQL Server
SA_PASSWORD=Grading!Str0ng

# ─── RabbitMQ (broker + MassTransit credentials)
RABBITMQ_USER=grading
RABBITMQ_PASSWORD=grading_pass

# ─── API (mapped into ASP.NET env in docker-compose.yml)
ASPNETCORE_URLS=http://+:8080
CORS_ORIGIN_0=http://localhost:3000

# ─── Worker (mapped into Worker__* in docker-compose.yml)
WORKER_MAX_CONCURRENT_JOBS=3
WORKER_POLL_INTERVAL_SECONDS=5
WORKER_ARTIFACT_HEALTH_TIMEOUT_SECONDS=30
WORKER_ARTIFACT_PORT_RANGE_START=7000
WORKER_ARTIFACT_PORT_RANGE_END=7999

# Optional: full path to newman in custom worker image
# WORKER_NEWMAN_EXECUTABLE=

# ─── Frontend build (Next.js only; not used by api/worker containers)
NEXT_PUBLIC_API_URL=http://localhost:5049/api
NEXT_PUBLIC_APP_URL=http://localhost:3000
