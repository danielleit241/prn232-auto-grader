### Grading System – PE_PRN232 Test File
### Base URL: http://localhost:5049

@base = http://localhost:5049
@api  = {{base}}/api/v1.0

# ── Paste IDs sau khi chạy từng bước ────────────────────────────────────────
@assignmentId = 00000000-0000-0000-0000-000000000000
@q1Id         = 00000000-0000-0000-0000-000000000000
@q2Id         = 00000000-0000-0000-0000-000000000000
@submissionId = 00000000-0000-0000-0000-000000000000
@gradingJobId = 00000000-0000-0000-0000-000000000000
@q1ResultId   = 00000000-0000-0000-0000-000000000000
@q2ResultId   = 00000000-0000-0000-0000-000000000000
@exportJobId  = 00000000-0000-0000-0000-000000000000


###############################################################################
# PHASE 1 – SETUP
###############################################################################

### 1.1 Tạo Assignment
POST {{api}}/assignments
Content-Type: application/json

{
  "title": "PE PRN232",
  "description": "REST API + Razor Pages"
}

###

### 1.2 Tạo Questions (Q1 + Q2 cùng lúc)
POST {{api}}/assignments/{{assignmentId}}/questions
Content-Type: application/json

[
  {
    "title": "Câu 1: REST API",
    "type": 0,
    "maxScore": 5,
    "artifactFolderName": "Q1"
  },
  {
    "title": "Câu 2: Razor Pages",
    "type": 1,
    "maxScore": 5,
    "artifactFolderName": "Q2"
  }
]

###

### 1.3 Upload database.sql + set GivenAPI URL
# Chạy teacher API trước, ghi lại port → đặt vào givenApiBaseUrl
PUT {{api}}/assignments/{{assignmentId}}/resources
Content-Type: multipart/form-data; boundary=----boundary

------boundary
Content-Disposition: form-data; name="givenApiBaseUrl"

http://localhost:5100
------boundary
Content-Disposition: form-data; name="databaseSql"; filename="database.sql"
Content-Type: text/plain

< ./database.sql
------boundary--

###############################################################################
# PHASE 1.4 – TEST CASES Q1  (type=Api, maxScore=5)
#
# Swagger mode  → không có expectedStatus VÀ không có input
#   Worker đọc swagger.json, kiểm tra path/method tồn tại + response schema
#
# HTTP mode     → có expectedStatus HOẶC có input
#   Worker gọi thực endpoint, kiểm tra status + JSON fields
#
# Tổng score phải bằng maxScore (5đ). Xoá trước nếu cần tạo lại.
###############################################################################

### 1.4 Tạo test cases Q1  (tổng 5đ)
# ── Swagger (4 cases) ───────────────────────────────────────────────────────
# GET /api/students               → array, fields: studentId studentName email gpa   (1đ)
# GET /api/student-performance    → object: data totalStudents totalPages current     (1đ)
# PUT /api/enrollments/{id}/grade → endpoint tồn tại                                 (1đ)
# DELETE /api/enrollments/{id}    → endpoint tồn tại                                 (1đ)
# ── HTTP (1 case) ───────────────────────────────────────────────────────────
# DELETE /api/enrollments/0                       → 404                              (1đ)
POST {{api}}/questions/{{q1Id}}/test-cases
Content-Type: application/json

[
  {
    "httpMethod": "GET",
    "urlTemplate": "/api/students",
    "isArray": true,
    "fields": ["studentId", "studentName", "email", "gpa"],
    "score": 1
  },
  {
    "httpMethod": "GET",
    "urlTemplate": "/api/student-performance",
    "fields": ["data", "totalStudents", "totalPages", "current", "pageSize"],
    "score": 1
  },
  {
    "httpMethod": "PUT",
    "urlTemplate": "/api/enrollments/{id}/grade",
    "score": 1
  },
  {
    "httpMethod": "DELETE",
    "urlTemplate": "/api/enrollments/{id}",
    "score": 1
  },
  {
    "httpMethod": "DELETE",
    "urlTemplate": "/api/enrollments/0",
    "expectedStatus": 404,
    "score": 1
  }
]

###############################################################################
# PHASE 1.5 – TEST CASES Q2  (type=Razor, maxScore=5)
#
# Tất cả đều là HTTP mode — gọi thật vào app, kiểm tra HTML response.
# App sinh viên nhận env GivenAPIBaseUrl để gọi API lấy data.
# Tổng score phải bằng maxScore (5đ).
###############################################################################

### 1.5 Tạo test cases Q2  (tổng 5đ)
# GET /Instructor              → 200, có <table>                          (1đ)
# GET /Instructor              → 200, có <form>                           (1đ)
# GET /Instructor              → 200, table có ít nhất 1 dòng dữ liệu    (1đ)
# GET /Instructor/{id}         → 200, có <table>                          (1đ)
# GET /Instructor/{id}         → 200, có <dl> hoặc detail layout          (1đ)
POST {{api}}/questions/{{q2Id}}/test-cases
Content-Type: application/json

[
  {
    "httpMethod": "GET",
    "urlTemplate": "/Instructor",
    "expectedStatus": 200,
    "selector": "table",
    "score": 1
  },
  {
    "httpMethod": "GET",
    "urlTemplate": "/Instructor",
    "expectedStatus": 200,
    "selector": "form",
    "score": 1
  },
  {
    "httpMethod": "GET",
    "urlTemplate": "/Instructor",
    "expectedStatus": 200,
    "selector": "table tbody tr",
    "selectorMinCount": 1,
    "score": 1
  },
  {
    "httpMethod": "GET",
    "urlTemplate": "/Instructor/1",
    "expectedStatus": 200,
    "selector": "table",
    "score": 1
  },
  {
    "httpMethod": "GET",
    "urlTemplate": "/Instructor/1",
    "expectedStatus": 200,
    "selector": "table tbody tr",
    "selectorMinCount": 1,
    "score": 1
  }
]

###############################################################################
# PHASE 2 – NỘP BÀI
###############################################################################

### 2.1 Upload artifact.zip
# Cấu trúc zip bắt buộc:
#   artifact.zip/
#   ├── Q1/    ← output của: dotnet publish Q1 -o publish/Q1
#   └── Q2/    ← output của: dotnet publish Q2 -o publish/Q2
POST {{api}}/submissions/upload
Content-Type: multipart/form-data; boundary=----boundary

------boundary
Content-Disposition: form-data; name="assignmentId"

{{assignmentId}}
------boundary
Content-Disposition: form-data; name="studentCode"

SE123456
------boundary
Content-Disposition: form-data; name="file"; filename="artifact.zip"
Content-Type: application/zip

< ./artifact.zip
------boundary--

###############################################################################
# PHASE 3 – GRADING
###############################################################################

### 3.1 Trigger grading
POST {{api}}/submissions/{{submissionId}}/grade

###

### 3.2 Poll trạng thái (Pending → Running → Done/Failed)
GET {{api}}/grading-jobs/{{gradingJobId}}

###

### 3.3 Xem kết quả từng câu (sau khi job Done)
GET {{api}}/submissions/{{submissionId}}/question-results

###############################################################################
# PHASE 4 – REVIEW
###############################################################################

### 4.1 Chỉnh điểm thủ công
PUT {{api}}/question-results/{{q1ResultId}}/adjust
Content-Type: application/json

{
  "adjustedScore": 4,
  "adjustReason": "Thiếu XML response format nhưng logic đúng",
  "adjustedBy": "gv@fpt.edu.vn"
}

###

### 4.2 Hủy chỉnh điểm (về điểm gốc)
DELETE {{api}}/question-results/{{q1ResultId}}/adjust

###

### 4.3 Nhận xét submission
PUT {{api}}/submissions/{{submissionId}}/notes
Content-Type: application/json

{
  "content": "Q1 đủ endpoints, GPA tính đúng. Q2 filter hoạt động, detail page OK.",
  "reviewedBy": "gv@fpt.edu.vn"
}

###############################################################################
# PHASE 5 – EXPORT EXCEL
###############################################################################

### 5.1 Tạo export job
POST {{api}}/exports
Content-Type: application/json

{
  "assignmentId": "{{assignmentId}}"
}

###

### 5.2 Tải file Excel (poll cho đến khi status Done)
GET {{api}}/exports/{{exportJobId}}/download

###############################################################################
# QUICK CHECKS
###############################################################################

### Danh sách assignments
GET {{api}}/assignments

###

### Assignment detail
GET {{api}}/assignments/{{assignmentId}}

###

### Questions của assignment
GET {{api}}/assignments/{{assignmentId}}/questions

###

### Test cases Q1
GET {{api}}/questions/{{q1Id}}/test-cases

###

### Test cases Q2
GET {{api}}/questions/{{q2Id}}/test-cases

###

### Xóa test cases Q1 (để tạo lại)
DELETE {{api}}/questions/{{q1Id}}/test-cases

###

### Xóa test cases Q2 (để tạo lại)
DELETE {{api}}/questions/{{q2Id}}/test-cases

###

### Danh sách submissions của assignment
GET {{api}}/assignments/{{assignmentId}}/submissions

###

### Danh sách submissions (filter theo studentCode)
GET {{api}}/assignments/{{assignmentId}}/submissions?studentCode=SE

###

### Submission detail
GET {{api}}/submissions/{{submissionId}}

###

### Grading jobs của submission
GET {{api}}/submissions/{{submissionId}}/grading-jobs

###

### Question result detail (Q1)
GET {{api}}/question-results/{{q1ResultId}}

###

### Question result detail (Q2)
GET {{api}}/question-results/{{q2ResultId}}
